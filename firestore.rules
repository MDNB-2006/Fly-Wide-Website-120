rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Phase 4: Validation Blueprints (Anti-Update-Gaps)
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'email'])
        && data.keys().size() >= 3
        && data.uid is string && data.uid.size() <= 128
        && data.fullName is string && data.fullName.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.uid == request.auth.uid;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['id', 'userId', 'destinationId', 'destinationName', 'fullName', 'email', 'travelDate', 'guests', 'totalCostUSD', 'currencyPaid', 'status'])
        && data.keys().size() >= 11
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.destinationId is string && data.destinationId.size() <= 128
        && data.destinationName is string && data.destinationName.size() <= 256
        && data.fullName is string && data.fullName.size() <= 250
        && data.email is string && data.email.size() <= 200
        && data.travelDate is string && data.travelDate.size() <= 50
        && data.guests is int && data.guests >= 1 && data.guests <= 1000
        && (data.totalCostUSD is float || data.totalCostUSD is int) && data.totalCostUSD >= 0
        && data.currencyPaid is string && data.currencyPaid.size() <= 10
        && data.status is string && (data.status == 'pending_payment' || data.status == 'completed')
        && data.userId == request.auth.uid;
    }

    // Match blocks

    // User collection rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if false;
    }

    // Bookings collection rules
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(request.resource.data);
      allow update: if isSignedIn() && isValidId(bookingId) 
        && isValidBooking(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.id == resource.data.id
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid 
        && resource.data.status == 'pending_payment';
    }
  }
}
